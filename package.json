{
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["bufferutil", "utf-8-validate"]
    }
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contracts:gate": "bash scripts/ci/contracts-gate.sh",
    "contracts:review": "tsx scripts/contracts-review-agent.ts"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.19",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4"
  }
}
