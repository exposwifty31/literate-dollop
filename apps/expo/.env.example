# API base for mobile client (inlined at build time — not for secrets)
EXPO_PUBLIC_API_URL=https://vettrack.uk

# Clerk publishable key (pk_* only — never sk_* secret key)
#
# When EXPO_PUBLIC_API_URL=https://vettrack.uk (production), you MUST use pk_live_*
# from clerk.vettrack.uk — same value as VITE_CLERK_PUBLISHABLE_KEY in vettrack .env
# (Capacitor native shell). Demo account reviewer@vettrack.uk exists only there.
#
# pk_test_* is for a separate Clerk dev instance; it will not find production users.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Set after `eas init` links this repo to an Expo project (also defaulted in app.config.ts)
# EAS_PROJECT_ID=5ec536d8-f991-4779-88d7-c1b7fa595cb5
